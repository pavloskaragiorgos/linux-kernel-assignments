diff --git a/mm/ept.c b/mm/ept.c
new file mode 100644
index 000000000..5b9be2401
--- /dev/null
+++ b/mm/ept.c
@@ -0,0 +1,295 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Expose Page Tables (EPT) - exposes process page tables to user-space
+ */
+
+#include <linux/module.h>
+#include <linux/kernel.h>
+#include <linux/miscdevice.h>
+#include <linux/fs.h>
+#include <linux/mm.h>
+#include <linux/slab.h>
+#include <linux/highmem.h>
+#include <linux/pgtable.h>
+#include <linux/sched.h>
+
+/*
+ * Walk the page table hierarchy to find the PTE page for a given virtual address.
+ * Returns the struct page containing the PTE entries, or NULL if not found.
+ */
+static struct page *ept_walk_to_pte_page(struct mm_struct *mm, unsigned long vaddr)
+{
+	pgd_t *pgd;
+	p4d_t *p4d;
+	pud_t *pud;
+	pmd_t *pmd;
+	pmd_t pmdval;
+	pte_t *ptep;
+
+	/* Validate address is within user space */
+	if (vaddr >= TASK_SIZE)
+		return NULL;
+
+	/* Walk the page table hierarchy */
+	pgd = pgd_offset(mm, vaddr);
+	if (pgd_none(READ_ONCE(*pgd)))
+		return NULL;
+
+	p4d = p4d_offset(pgd, vaddr);
+	if (p4d_none(READ_ONCE(*p4d)))
+		return NULL;
+
+	pud = pud_offset(p4d, vaddr);
+	if (pud_none(READ_ONCE(*pud)))
+		return NULL;
+
+	pmd = pmd_offset(pud, vaddr);
+	pmdval = READ_ONCE(*pmd);
+	if (pmd_none(pmdval))
+		return NULL;
+
+	/*
+	 * Huge pages are not supported.
+	 * Neither are transparent huge pages (THP) and device mappings.
+	 */
+	if (pmd_trans_huge(pmdval) || pmd_devmap(pmdval))
+		return NULL;
+
+	/*
+	 * Verify the PTE level exists by attempting to map it.
+	 * We immediately unmap since we only need the page, not the pointer.
+	 */
+	ptep = pte_offset_map(pmd, vaddr);
+	if (!ptep)
+		return NULL;
+
+	pte_unmap(ptep);
+
+	/* Return the struct page for the PTE table */
+	return pmd_page(pmdval);
+}
+
+/*
+ * Custom fault handler for EPT mappings
+ *
+ * When user accesses ept[N], this handler walks the multi-level page table
+ * to find the PTE page containing the entry for virtual page N.
+ * If any level is missing, the zero page is returned instead.
+ */
+static vm_fault_t ept_fault(struct vm_fault *vmf)
+{
+	struct vm_area_struct *vma = vmf->vma;
+	struct mm_struct *mm = vma->vm_mm;
+	unsigned long target_vaddr;
+	struct page *pte_page;
+	unsigned long pfn;
+
+	/*
+	 * Calculate the target virtual address from the EPT page index.
+	 * Each EPT page covers PTRS_PER_PTE virtual pages.
+	 * vmf->pgoff is the EPT page number.
+	 */
+	target_vaddr = vmf->pgoff * PTRS_PER_PTE * PAGE_SIZE;
+
+	/* Walk to find the PTE page */
+	pte_page = ept_walk_to_pte_page(mm, target_vaddr);
+
+	if (!pte_page)
+		goto return_zero_page;
+
+	/* Get the PFN and validate it */
+	pfn = page_to_pfn(pte_page);
+	if (!pfn_valid(pfn))
+		goto return_zero_page;
+
+	/*
+	 * Insert the PTE table page into user's address space.
+	 * VM_PFNMAP allows vmf_insert_pfn with valid PFNs.
+	 */
+	return vmf_insert_pfn(vma, vmf->address, pfn);
+
+return_zero_page:
+	/*
+	 * No valid PTE table exists for this virtual address.
+	 * Return the zero page so user-space sees all-zero PTE entries.
+	 */
+	return vmf_insert_pfn(vma, vmf->address, my_zero_pfn(vmf->address));
+}
+
+static const struct vm_operations_struct ept_vm_ops = {
+	.fault = ept_fault,
+};
+
+
+/*
+ * open handler for /dev/ept
+ * Only system administrators (root) can open this device
+ */
+static int ept_open(struct inode *inode, struct file *file)
+{
+	if (!capable(CAP_SYS_ADMIN))
+		return -EPERM;
+
+	return 0;
+}
+
+/*
+ * mmap handler for /dev/ept
+ * Sets up VMA with custom operations
+ */
+static int ept_mmap(struct file *file, struct vm_area_struct *vma)
+{
+	/* Only root can mmap /dev/ept - double check */
+	if (!capable(CAP_SYS_ADMIN))
+		return -EPERM;
+
+	/* Reject write mappings - page tables are read-only via EPT */
+	if (vma->vm_flags & VM_WRITE)
+		return -EPERM;
+
+	/* Set custom VM operations */
+	vma->vm_ops = &ept_vm_ops;
+
+	/*
+	 * Set flags for VM_PFNMAP:
+	 * - VM_PFNMAP: We insert PFNs directly via vmf_insert_pfn
+	 * - VM_DONTEXPAND: Don't allow mremap to expand
+	 * - VM_DONTDUMP: Don't include in core dumps
+	 * - VM_IO: Prevents CoW and other optimizations
+	 *
+	 * Clear VM_MAYWRITE to prevent CoW mapping issues.
+	 * vmf_insert_pfn will BUG_ON if VM_PFNMAP && is_cow_mapping().
+	 */
+	vm_flags_set(vma, VM_PFNMAP | VM_DONTEXPAND | VM_DONTDUMP | VM_IO);
+	vm_flags_clear(vma, VM_MAYWRITE);
+
+	return 0;
+}
+
+/*  File operations for /dev/ept (the custom actions our driver supports)*/
+static const struct file_operations ept_fops = {
+	.owner = THIS_MODULE,
+	.open = ept_open,
+	.mmap = ept_mmap,
+};
+
+/* Miscdevice structure for /dev/ept */
+static struct miscdevice ept_dev = {
+	.minor = MISC_DYNAMIC_MINOR,
+	.fops  = &ept_fops, /* File operations defined above*/
+	.name  = "ept", /* Device name: /dev/ept */
+	.mode  = 0600, /* Only root can access */
+};
+
+/*
+ * Module initialization
+ */
+static int __init ept_init(void)
+{
+	int ret;
+
+	ret = misc_register(&ept_dev);
+	if (ret) {
+		pr_err("ept: failed to register misc device: %d\n", ret);
+		return ret;
+	}
+
+	return 0;
+}
+
+/*
+ * Module cleanup
+ */
+static void __exit ept_exit(void)
+{
+	misc_deregister(&ept_dev);
+}
+
+module_init(ept_init);
+module_exit(ept_exit);
+
+
+/*
+ * Calculate which EPT page corresponds to a virtual address (the idx in ept[idx]).
+ */
+static inline unsigned long virt_addr_to_ept_page(unsigned long address)
+{
+	/* divide by PAGE_SIZE to get virtual page number (idx in ept[idx]) */
+	unsigned long virt_page_num = address >> PAGE_SHIFT;
+	/* divide by the num of pages (#PTRS_PER_PTE) to get EPT page number */
+	return virt_page_num / PTRS_PER_PTE;
+}
+/*
+ * Check if a given EPT page falls within a VMA's range.
+ */
+static bool ept_page_in_vma_range(struct vm_area_struct *vma,
+				  unsigned long ept_page_num)
+{
+	/* Starting EPT page number for this VMA */
+	unsigned long vma_start_ept_page = vma->vm_pgoff;
+	/* Number of virtual pages covered by this VMA */
+	unsigned long vma_num_ept_pages = (vma->vm_end - vma->vm_start) >>
+					  PAGE_SHIFT;
+	/* Ending EPT page number for this VMA */
+	unsigned long vma_end_ept_page = vma_start_ept_page + vma_num_ept_pages;
+
+	/* Check if the EPT page number falls within the VMA's EPT page range */
+	return ept_page_num >= vma_start_ept_page &&
+	       ept_page_num < vma_end_ept_page;
+}
+
+/*
+ * Invalidate a single EPT page within a VMA.
+ * Calculates the correct address and calls zap_page_range_single.
+ */
+static void invalidate_ept_page_in_vma(struct vm_area_struct *vma,
+				       unsigned long ept_page_num)
+{
+	/* how many bytes (multiplied by PAGE_SIZE) into the VMA the given
+	 * EPT page starts
+	 */
+	unsigned long offset_in_vma = (ept_page_num - vma->vm_pgoff) <<
+				      PAGE_SHIFT;
+	/* Calculate the exact virtual address within the VMA corresponding
+	 * to the EPT page
+	 */
+	unsigned long zap_addr = vma->vm_start + offset_in_vma;
+
+	/* Sanity check: ensure address is within VMA bounds */
+	if (zap_addr >= vma->vm_start && zap_addr < vma->vm_end)
+		zap_page_range_single(vma, zap_addr, PAGE_SIZE, NULL);
+}
+
+/*
+ * Invalidate EPT mappings for a given virtual address (ept[idx], idx:
+ * corresponding to given address, calculated within).
+ * Called when free_pte_range or pmd_install are called.
+ *
+ * This ensures that EPT is updated and
+ * 1) stale EPT mappings don't point to freed page tables (if freed),
+ * 2) EPT mappings of valid pages don't point to zeroed pages (if created).
+ * The next access will trigger the fault handler to re-walk the page tables.
+ */
+void ept_invalidate_mapping(struct mm_struct *mm, unsigned long address)
+{
+	struct vm_area_struct *vma;
+	unsigned long ept_page_num;
+
+	VMA_ITERATOR(vmi, mm, 0);
+
+	if (!mm)
+		return;
+
+	/* Calculate which EPT page needs invalidation */
+	ept_page_num = virt_addr_to_ept_page(address);
+
+	/* Find all EPT VMAs and invalidate the relevant EPT page */
+	for_each_vma(vmi, vma) {
+		if (vma->vm_ops != &ept_vm_ops)
+			continue;
+
+		if (ept_page_in_vma_range(vma, ept_page_num))
+			invalidate_ept_page_in_vma(vma, ept_page_num);
+	}
+}
+EXPORT_SYMBOL(ept_invalidate_mapping);
